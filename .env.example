# ─────────────────────────────────────────────────────────────────────────────
# weekly_market_condition — Konfigurationsvorlage
#
# 1. Diese Datei nach ".env" kopieren:   cp .env.example .env
# 2. Werte in .env anpassen
# 3. .env wird NICHT ins Repository gepusht (steht in .gitignore)
#
# Für den automatischen GitHub-Actions-Lauf dieselben Variablen als
# "Repository Secrets" unter Settings → Secrets and variables → Actions setzen.
# ─────────────────────────────────────────────────────────────────────────────


# ── Universe ──────────────────────────────────────────────────────────────────
# Welche Aktien sollen analysiert werden?
#
#   csv            → lokale CSV-Datei (Standardverhalten, kein Internet nötig)
#   ishares_iwv    → iShares Russell 3000 (Top ~3000 US-Aktien, empfohlen)
#   ishares_iwb    → iShares Russell 1000 (Top ~1000 US-Aktien)
#   ishares_iwm    → iShares Russell 2000 (Small Caps)
#
UNIVERSE=ishares_iwv

# Wie viele der größten Aktien aus dem ETF sollen analysiert werden?
# iShares IWV enthält ~3000 Aktien; Top 2000 nach ETF-Gewichtung ≈ Top 2000 nach Marktkapitalisierung.
UNIVERSE_TOP_N=2000


# ── E-Mail ────────────────────────────────────────────────────────────────────
MAIL_FROM=deine@email.de
MAIL_TO=empfaenger@email.de
MAIL_SUBJECT_PREFIX=Weekly US Market Report

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine@email.de
SMTP_PASS=dein-app-passwort


# ── Output ────────────────────────────────────────────────────────────────────
# Excel-Datei erzeugen und als Anhang versenden?
# false = nur JSON-Signale + HTML-Mail (Standard, schneller)
# true  = zusätzlich vollständige Excel-Datei mit allen 2000 Aktien
EXPORT_EXCEL=false


# ── Portfolio & Positionsgröße ────────────────────────────────────────────────
# Kontogröße in EUR/USD (für Kelly-Positionsgröße)
ACCOUNT_EQUITY=100000

# Maximale Anzahl Top-Picks (Gold-Badge in der E-Mail)
MAX_POSITIONS=5

# Nur Industrien mit diesem Ranking oder besser (1 = stärkste Industrie)
MAX_INDUSTRY_RANK=50


# ── Strategie-Parameter (Blueprint-Defaults, selten ändern) ──────────────────
WIN_RATE=0.59
WIN_LOSS_RATIO=4.04
KELLY_FRACTION=0.33

# Positionsgröße in bärischem Markt (S&P 500 10W EMA < 20W EMA).
# Multiplikator auf KELLY_FRACTION. 0.5 = halbe Größe → kein harter Block, aber reduziertes Risiko.
BEARISH_KELLY_FRACTION=0.5


# ── Technisch ─────────────────────────────────────────────────────────────────
LOOKBACK_WEEKS=60
CACHE_DIR=.cache
